name: mav
title: Mav
base: core24
version: "$RELEASE_VERSION"
summary: The editor for what's next
description: |
  Mav is a modern open-source code editor, built from the ground up in Rust with
  a GPU-accelerated renderer. We help you build software faster than ever before.
grade: stable
confinement: classic
compression: lzo
website: https://mav.dev/
source-code: https://github.com/mav-industries/mav
issues: https://github.com/mav-industries/mav/issues
contact: https://mav.dev/community-links#support-and-feedback

parts:
  mav:
    plugin: dump
    source: "https://github.com/mav-industries/mav/releases/download/v$RELEASE_VERSION/mav-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Mav exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Mav exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  mav:
    command: usr/bin/mav
    common-id: dev.mav.Mav
    environment:
      MAV_BUNDLE_TYPE: snap
